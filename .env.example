# ============================================================
# Beacon LMS — Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# Never commit the real .env file to version control.
# ============================================================

# -----------------------------------------------------------
# Django Core
# -----------------------------------------------------------

# A long, randomly generated secret string used by Django for
# cryptographic signing (sessions, CSRF tokens, password resets).
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=your-long-random-secret-key-here

# Set to True only during local development.
# Must be False in any production or staging environment.
DEBUG=True

# -----------------------------------------------------------
# Database
# -----------------------------------------------------------

# Full PostgreSQL connection string consumed by dj-database-url.
# Format: postgres://<USER>:<PASSWORD>@<HOST>:<PORT>/<DB_NAME>
# For local development, replace each placeholder with your actual credentials.
# In production (Render, Heroku, etc.), this is typically injected automatically.
DATABASE_URL=postgres://beacon_user:your_db_password@localhost:5432/beacon_lms

# -----------------------------------------------------------
# Frontend (React)
# -----------------------------------------------------------

# The React frontend currently sets the backend API base URL directly in
# src/api.js rather than reading from an environment variable.
# The base URL of the Django backend API consumed by the React app.
# For local development, point this at your local Django server.
# In production (e.g., Render, Vercel), set this to your deployed backend URL.
REACT_APP_API_URL=http://localhost:8000
